{
    "buildCommand": "uv sync && uv run pip install -e .",
    "startCommand": "uv run uvicorn server:app --host 0.0.0.0 --port ${PORT:-8000}",
    "envVars": [
        {
            "key": "ENVIRONMENT",
            "value": "production",
            "previewValue": "development"
        }
    ]
}